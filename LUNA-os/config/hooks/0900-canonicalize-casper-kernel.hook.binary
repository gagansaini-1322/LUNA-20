#!/bin/sh
set -e
# Create /live/vmlinuz and /live/initrd symlinks to the versioned kernel
# This allows generic kernel paths in bootloader configs
if [ -d binary/live ]; then
    cd binary/live
    for f in vmlinuz-*; do
        [ -f "$f" ] || continue
        ln -sf "$f" vmlinuz
        break
    done
    for f in initrd.img-*; do
        [ -f "$f" ] || continue
        ln -sf "$f" initrd
        break
    done
    cd /
fi
