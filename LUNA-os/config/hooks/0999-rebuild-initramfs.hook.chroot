#!/bin/sh
set -e
# Force rebuild initramfs to include casper's live-boot hooks.
# Must run after all packages are installed so casper is present.
echo "[luna-hook] Rebuilding initramfs..."
if update-initramfs -u; then
    echo "[luna-hook] initramfs rebuild done."
else
    echo "[luna-hook] WARNING: update-initramfs failed (non-fatal in chroot)."
fi
