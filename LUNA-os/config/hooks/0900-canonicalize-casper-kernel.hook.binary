#!/bin/sh
set -e
# Create /casper/vmlinuz and /casper/initrd.img symlinks to the versioned kernel
# This allows generic kernel paths in bootloader configs
if [ -d binary/casper ]; then
    cd binary/casper
    for f in vmlinuz-*; do
        [ -f "$f" ] || continue
        ln -sf "$f" vmlinuz
        break
    done
    for f in initrd.img-*; do
        [ -f "$f" ] || continue
        ln -sf "$f" initrd.img
        break
    done
    cd /
fi
