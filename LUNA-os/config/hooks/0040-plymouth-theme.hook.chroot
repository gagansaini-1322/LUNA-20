#!/bin/sh
set -e
echo "[luna-hook] Registering Luna Plymouth theme..."

# Ubuntu uses update-alternatives (not plymouth-set-default-theme)
update-alternatives --install /usr/share/plymouth/themes/default.plymouth \
    default.plymouth \
    /usr/share/plymouth/themes/luna/luna.plymouth 200 || true
update-alternatives --set default.plymouth \
    /usr/share/plymouth/themes/luna/luna.plymouth || true

update-initramfs -u || true
echo "[luna-hook] Plymouth theme registered."
